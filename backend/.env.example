# Flask Configuration
SECRET_KEY=drivesafe-secret-key-change-me

# MariaDB Configuration
# Format: mysql+pymysql://user:password@host/dbname
DATABASE_URL=mysql+pymysql://drivesafe_user:YOUR_PASSWORD@localhost/drivesafe_prod

# Google Service Account
# Path to the JSON key file you generated in Google Cloud Console
SERVICE_ACCOUNT_JSON=backend/service_account.json

# Google Sheets Configuration
# The ID is found in the Sheet URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
SHEET_ID=YOUR_GOOGLE_SHEET_ID_HERE

# Archival Configuration
ARCHIVE_ROOT=Capstone_Archives

# Frontend (Vite) - For Google Login
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
